# Groq API key (Preferred for fast, cost-efficient inference)
GROQ_API_KEY=gsk_your_groq_api_key_here


# Hindsight API key — for session tracing & observability
# Leave empty in dev if you don't have one yet (logging will be skipped)
HINDSIGHT_API_KEY=your_hindsight_api_key_here
